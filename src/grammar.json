{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/grammar.schema.json",
  "name": "logstash",
  "rules": {
    "source_file": {
      "type": "REPEAT",
      "content": {
        "type": "SYMBOL",
        "name": "pipeline"
      }
    },
    "pipeline": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "input_section"
        },
        {
          "type": "SYMBOL",
          "name": "filter_section"
        },
        {
          "type": "SYMBOL",
          "name": "output_section"
        }
      ]
    },
    "input_section": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "input"
        },
        {
          "type": "STRING",
          "value": "{"
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "SYMBOL",
            "name": "block"
          }
        },
        {
          "type": "STRING",
          "value": "}"
        }
      ]
    },
    "filter_section": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "filter"
        },
        {
          "type": "STRING",
          "value": "{"
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "SYMBOL",
            "name": "section_content"
          }
        },
        {
          "type": "STRING",
          "value": "}"
        }
      ]
    },
    "output_section": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "output"
        },
        {
          "type": "STRING",
          "value": "{"
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "SYMBOL",
            "name": "section_content"
          }
        },
        {
          "type": "STRING",
          "value": "}"
        }
      ]
    },
    "section_content": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "block"
        },
        {
          "type": "SYMBOL",
          "name": "conditional"
        }
      ]
    },
    "conditional": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "if"
        },
        {
          "type": "SYMBOL",
          "name": "condition"
        },
        {
          "type": "STRING",
          "value": "{"
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "SYMBOL",
            "name": "section_content"
          }
        },
        {
          "type": "STRING",
          "value": "}"
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "SYMBOL",
            "name": "else_if"
          }
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SYMBOL",
              "name": "else"
            },
            {
              "type": "BLANK"
            }
          ]
        }
      ]
    },
    "else_if": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "else"
        },
        {
          "type": "STRING",
          "value": "if"
        },
        {
          "type": "SYMBOL",
          "name": "condition"
        },
        {
          "type": "STRING",
          "value": "{"
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "SYMBOL",
            "name": "section_content"
          }
        },
        {
          "type": "STRING",
          "value": "}"
        }
      ]
    },
    "else": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "else"
        },
        {
          "type": "STRING",
          "value": "{"
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "SYMBOL",
            "name": "section_content"
          }
        },
        {
          "type": "STRING",
          "value": "}"
        }
      ]
    },
    "condition": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "boolean_condition"
        },
        {
          "type": "SYMBOL",
          "name": "comparison"
        },
        {
          "type": "SYMBOL",
          "name": "regexp_comparison"
        },
        {
          "type": "SYMBOL",
          "name": "inclusion"
        },
        {
          "type": "SYMBOL",
          "name": "not_condition"
        },
        {
          "type": "SYMBOL",
          "name": "condition_value"
        }
      ]
    },
    "boolean_condition": {
      "type": "PREC_LEFT",
      "value": 0,
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "SYMBOL",
            "name": "condition"
          },
          {
            "type": "CHOICE",
            "members": [
              {
                "type": "STRING",
                "value": "and"
              },
              {
                "type": "STRING",
                "value": "or"
              },
              {
                "type": "STRING",
                "value": "xor"
              },
              {
                "type": "STRING",
                "value": "nand"
              }
            ]
          },
          {
            "type": "SYMBOL",
            "name": "condition"
          }
        ]
      }
    },
    "comparison": {
      "type": "PREC_LEFT",
      "value": 0,
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "SYMBOL",
            "name": "condition_value"
          },
          {
            "type": "CHOICE",
            "members": [
              {
                "type": "STRING",
                "value": "=="
              },
              {
                "type": "STRING",
                "value": "!="
              },
              {
                "type": "STRING",
                "value": "<"
              },
              {
                "type": "STRING",
                "value": ">"
              },
              {
                "type": "STRING",
                "value": "<="
              },
              {
                "type": "STRING",
                "value": ">="
              }
            ]
          },
          {
            "type": "SYMBOL",
            "name": "condition_value"
          }
        ]
      }
    },
    "regexp_comparison": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
          "name": "condition_value"
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "STRING",
              "value": "=~"
            },
            {
              "type": "STRING",
              "value": "!~"
            }
          ]
        },
        {
          "type": "SYMBOL",
          "name": "condition_value"
        }
      ]
    },
    "inclusion": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
          "name": "condition_value"
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "STRING",
              "value": "in"
            },
            {
              "type": "SEQ",
              "members": [
                {
                  "type": "STRING",
                  "value": "not"
                },
                {
                  "type": "STRING",
                  "value": "in"
                }
              ]
            }
          ]
        },
        {
          "type": "SYMBOL",
          "name": "condition_value"
        }
      ]
    },
    "not_condition": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "!"
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SYMBOL",
              "name": "comparison"
            },
            {
              "type": "SYMBOL",
              "name": "regexp_comparison"
            },
            {
              "type": "SYMBOL",
              "name": "inclusion"
            },
            {
              "type": "SYMBOL",
              "name": "condition_value"
            }
          ]
        }
      ]
    },
    "condition_value": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "string"
        },
        {
          "type": "SYMBOL",
          "name": "field_reference"
        },
        {
          "type": "SYMBOL",
          "name": "plugin_name"
        },
        {
          "type": "SYMBOL",
          "name": "number"
        },
        {
          "type": "SYMBOL",
          "name": "boolean"
        }
      ]
    },
    "field_reference": {
      "type": "REPEAT1",
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "STRING",
            "value": "["
          },
          {
            "type": "PATTERN",
            "value": "[^\\]]+"
          },
          {
            "type": "STRING",
            "value": "]"
          }
        ]
      }
    },
    "block": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
          "name": "plugin_name"
        },
        {
          "type": "STRING",
          "value": "{"
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "SYMBOL",
            "name": "block_content"
          }
        },
        {
          "type": "STRING",
          "value": "}"
        }
      ]
    },
    "block_content": {
      "type": "CHOICE",
      "members": [
        {
          "type": "PREC",
          "value": 1,
          "content": {
            "type": "SYMBOL",
            "name": "expression"
          }
        },
        {
          "type": "SYMBOL",
          "name": "assignment"
        },
        {
          "type": "SYMBOL",
          "name": "block"
        }
      ]
    },
    "assignment": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
          "name": "expression_key"
        },
        {
          "type": "TOKEN",
          "content": {
            "type": "PREC",
            "value": -1,
            "content": {
              "type": "STRING",
              "value": "="
            }
          }
        },
        {
          "type": "SYMBOL",
          "name": "expression_value"
        }
      ]
    },
    "expression": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
          "name": "expression_key"
        },
        {
          "type": "STRING",
          "value": "=>"
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "PREC",
              "value": 1,
              "content": {
                "type": "SYMBOL",
                "name": "expression_value"
              }
            },
            {
              "type": "SYMBOL",
              "name": "block"
            }
          ]
        }
      ]
    },
    "expression_key": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "string"
        },
        {
          "type": "ALIAS",
          "content": {
            "type": "SYMBOL",
            "name": "plugin_name"
          },
          "named": false,
          "value": "identifier"
        }
      ]
    },
    "expression_value": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "string"
        },
        {
          "type": "ALIAS",
          "content": {
            "type": "SYMBOL",
            "name": "plugin_name"
          },
          "named": false,
          "value": "identifier"
        },
        {
          "type": "SYMBOL",
          "name": "number"
        },
        {
          "type": "SYMBOL",
          "name": "boolean"
        },
        {
          "type": "SYMBOL",
          "name": "array"
        },
        {
          "type": "SYMBOL",
          "name": "hash"
        },
        {
          "type": "SYMBOL",
          "name": "bytes"
        }
      ]
    },
    "whitespace": {
      "type": "PATTERN",
      "value": "\\s+"
    },
    "comment": {
      "type": "TOKEN",
      "content": {
        "type": "PREC",
        "value": -10,
        "content": {
          "type": "PATTERN",
          "value": "#[^\\r\\n]*"
        }
      }
    },
    "string": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "double_quoted_string"
        },
        {
          "type": "SYMBOL",
          "name": "single_quoted_string"
        }
      ]
    },
    "double_quoted_string": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "\""
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "CHOICE",
            "members": [
              {
                "type": "SYMBOL",
                "name": "double_quoted_content"
              },
              {
                "type": "SYMBOL",
                "name": "string_var"
              }
            ]
          }
        },
        {
          "type": "STRING",
          "value": "\""
        }
      ]
    },
    "single_quoted_string": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "'"
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "SYMBOL",
            "name": "single_quoted_content"
          }
        },
        {
          "type": "STRING",
          "value": "'"
        }
      ]
    },
    "double_quoted_content": {
      "type": "TOKEN",
      "content": {
        "type": "PREC",
        "value": 2,
        "content": {
          "type": "PATTERN",
          "value": "[^\"\\\\%]+|\\\\."
        }
      }
    },
    "single_quoted_content": {
      "type": "TOKEN",
      "content": {
        "type": "PREC",
        "value": 2,
        "content": {
          "type": "PATTERN",
          "value": "[^'\\\\]+|\\\\."
        }
      }
    },
    "string_var": {
      "type": "TOKEN",
      "content": {
        "type": "CHOICE",
        "members": [
          {
            "type": "SEQ",
            "members": [
              {
                "type": "STRING",
                "value": "%{{"
              },
              {
                "type": "PATTERN",
                "value": "[^}]+"
              },
              {
                "type": "STRING",
                "value": "}"
              }
            ]
          },
          {
            "type": "SEQ",
            "members": [
              {
                "type": "STRING",
                "value": "%{"
              },
              {
                "type": "PATTERN",
                "value": "[^}]+"
              },
              {
                "type": "STRING",
                "value": "}"
              }
            ]
          }
        ]
      }
    },
    "plugin_name": {
      "type": "TOKEN",
      "content": {
        "type": "PATTERN",
        "value": "[a-zA-Z_][a-zA-Z0-9_]*"
      }
    },
    "number": {
      "type": "TOKEN",
      "content": {
        "type": "PATTERN",
        "value": "\\d+(\\.\\d+)?"
      }
    },
    "boolean": {
      "type": "TOKEN",
      "content": {
        "type": "CHOICE",
        "members": [
          {
            "type": "STRING",
            "value": "true"
          },
          {
            "type": "STRING",
            "value": "false"
          }
        ]
      }
    },
    "bytes": {
      "type": "TOKEN",
      "content": {
        "type": "PATTERN",
        "value": "\\d+\\s*[kKmMgGtTpPeEzZyY]i?[bB]"
      }
    },
    "hash": {
      "type": "PREC",
      "value": 1,
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "STRING",
            "value": "{"
          },
          {
            "type": "REPEAT",
            "content": {
              "type": "SYMBOL",
              "name": "hash_entry"
            }
          },
          {
            "type": "STRING",
            "value": "}"
          }
        ]
      }
    },
    "hash_entry": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
          "name": "expression_key"
        },
        {
          "type": "STRING",
          "value": "=>"
        },
        {
          "type": "SYMBOL",
          "name": "expression_value"
        }
      ]
    },
    "array": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "["
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SEQ",
              "members": [
                {
                  "type": "SYMBOL",
                  "name": "expression_value"
                },
                {
                  "type": "REPEAT",
                  "content": {
                    "type": "SEQ",
                    "members": [
                      {
                        "type": "STRING",
                        "value": ","
                      },
                      {
                        "type": "SYMBOL",
                        "name": "expression_value"
                      }
                    ]
                  }
                },
                {
                  "type": "CHOICE",
                  "members": [
                    {
                      "type": "STRING",
                      "value": ","
                    },
                    {
                      "type": "BLANK"
                    }
                  ]
                }
              ]
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "STRING",
          "value": "]"
        }
      ]
    }
  },
  "extras": [
    {
      "type": "SYMBOL",
      "name": "whitespace"
    },
    {
      "type": "SYMBOL",
      "name": "comment"
    }
  ],
  "conflicts": [
    [
      "block",
      "expression_value"
    ]
  ],
  "precedences": [],
  "externals": [],
  "inline": [],
  "supertypes": [],
  "reserved": {}
}